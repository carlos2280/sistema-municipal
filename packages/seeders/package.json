{
  "name": "@municipal/seeders",
  "version": "1.0.0",
  "description": "Seeders, migraciones y utilidades de DB para el sistema municipal",
  "type": "module",
  "private": true,
  "scripts": {
    "seed": "tsx src/index.ts",
    "migrate": "tsx src/migrate.ts",
    "generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "platform:generate": "tsx node_modules/drizzle-kit/bin.cjs generate --config drizzle.platform.config.ts",
    "platform:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate --config drizzle.platform.config.ts",
    "platform:push": "tsx node_modules/drizzle-kit/bin.cjs push --config drizzle.platform.config.ts",
    "platform:studio": "tsx node_modules/drizzle-kit/bin.cjs studio --config drizzle.platform.config.ts",
    "platform:seed": "tsx src/platform.seed.ts",
    "tenant:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate --config drizzle.tenant.config.ts"
  },
  "dependencies": {
    "@municipal/core": "workspace:*",
    "@municipal/db-contabilidad": "workspace:*",
    "@municipal/db-identidad": "workspace:*",
    "@municipal/db-mensajeria": "workspace:*",
    "@municipal/db-platform": "workspace:*",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "pg": "^8.16.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
