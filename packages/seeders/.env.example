# ============================================
# Package Seeders - Variables de Entorno (Template)
# ============================================
# Variables para migraciones y conexión DB
# Copia este archivo a .env y configura los valores
# ============================================

# Database - Credenciales
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=muni_default
DB_SSL=false

# Platform DB
PLATFORM_DB_NAME=platform

# Pool
DB_POOL_MIN=1
DB_POOL_MAX=10

# Environment
NODE_ENV=development
