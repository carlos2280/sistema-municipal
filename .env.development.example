# ============================================
# Sistema Municipal - Desarrollo (EJEMPLO)
# ============================================
# Copiar a .env.development y completar con valores reales.
# NUNCA commitear .env.development con valores reales.
# ============================================

NODE_ENV=development

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_CONTRASEÑA_SEGURA
POSTGRES_DB=muni_default
POSTGRES_PORT=5434
DATABASE_URL=postgresql://postgres:CAMBIAR_CONTRASEÑA_SEGURA@localhost:5434/muni_default

# Redis (puerto 6380 externo para evitar conflictos)
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# Mailhog (puertos externos modificados para evitar conflictos)
MAILHOG_SMTP_PORT=1026
MAILHOG_UI_PORT=8026
SMTP_HOST=localhost
SMTP_PORT=1026

# JWT — generar con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_MINIMO_32_CHARS_RANDOM
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# API Ports
API_GATEWAY_PORT=3000
API_IDENTIDAD_PORT=3001
API_CONTABILIDAD_PORT=3002
API_AUTORIZACION_PORT=3003
API_CHAT_PORT=3005
API_PLATFORM_PORT=3006

# Microfrontend Ports
MF_SHELL_PORT=5030
MF_STORE_PORT=5010
MF_UI_PORT=5011
MF_CONTABILIDAD_PORT=5020

# Microfrontend URLs
VITE_API_URL=http://localhost:3000
VITE_MF_STORE_URL=http://localhost:5010/assets/remoteEntry.js
VITE_MF_UI_URL=http://localhost:5011/assets/remoteEntry.js
VITE_MF_CONTABILIDAD_URL=http://localhost:5020/assets/remoteEntry.js
