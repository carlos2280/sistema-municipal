# ============================================
# API Identidad - Variables de Entorno (Template)
# ============================================
# ALTAMENTE SENSIBLE - Solo acceso equipo core
# Copia este archivo a .env y configura los valores
# ============================================

# Puerto
PORT=3001

# Database - Credenciales
DB_USER=postgres
DB_PASSWORD=your-secure-password

# JWT - Secrets de autenticación
JWT_SECRET=generate-secure-random-string
JWT_REFRESH_SECRET=generate-another-secure-random-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption - Para datos sensibles (debe ser 32 caracteres)
ENCRYPTION_KEY=your-32-character-encryption-key

# MFA — Clave AES-256-GCM para cifrar secretos TOTP (32 bytes = 64 hex chars)
# Generar con: openssl rand -hex 32
# OBLIGATORIA en producción — nunca reutilizar entre entornos
MFA_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# OAuth providers (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Password hashing
BCRYPT_ROUNDS=12

# Session
SESSION_SECRET=generate-secure-session-secret

# Logging (debug, info, warn, error)
LOG_LEVEL=info
