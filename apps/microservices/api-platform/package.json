{
  "name": "api-platform",
  "version": "1.0.0",
  "description": "Microservicio de plataforma SaaS - Gestión de tenants, módulos y suscripciones",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --no-splitting --clean --minify",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "@municipal/core": "workspace:*",
    "@municipal/db-platform": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "express": "^5.1.0",
    "pg": "^8.16.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.18.12",
    "@types/pg": "^8.15.2",
    "cross-env": "^7.0.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
