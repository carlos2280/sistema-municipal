# ============================================
# API Gateway - Variables de Entorno (Template)
# ============================================
# Copia este archivo a .env y configura los valores
# ============================================

# Puerto
PORT=3000

# JWT para validación de tokens
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (separados por coma)
CORS_ORIGINS=http://localhost:5030

# URLs de microservicios internos
AUTH_URL=http://localhost:3003
IDENTITY_URL=http://localhost:3001
CONTABILIDAD_URL=http://localhost:3002
CHAT_URL=http://localhost:3004
PLATFORM_URL=http://localhost:3006

# Admin API key (must match api-platform)
ADMIN_API_KEY=change-me-in-production

# Logging (debug, info, warn, error)
LOG_LEVEL=debug
